[Unit]
Description=Power Trading Platform - Frontend (Next.js)
After=network.target

[Service]
User=kartik-gcp
Group=kartik-gcp
WorkingDirectory=/home/kartik-gcp/makeathon-20/frontend
Environment="PATH=/usr/local/bin:/usr/bin"
Environment="NODE_ENV=production"
ExecStart=/usr/bin/npx next start -p 3000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
